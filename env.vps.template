# GaiaLog VPS template
# Dedicated single-writer process for queue mutation, UTXO maintenance,
# signing, ARC broadcasting, and overlay submission.

NODE_ENV=production
GAIALOG_WORKER_PROCESS=1
GAIALOG_SINGLE_WRITER_MODE=run-workers
GAIALOG_MUTATOR_ROLE=primary
GAIALOG_NO_DB=false
BSV_ENABLE_UTXO_DB_LOCKS=true
# Heap guard: 0.98 allows more headroom before pausing (avoids HEAP_PRESSURE_BACKOFF)
BSV_HEAP_GUARD_HIGH_WATERMARK=0.98
BSV_HEAP_GUARD_PAUSE_MS=10000
BSV_UTXO_MAINTAINER_DISABLED=false

# Spend-source rollout
# Parallel cutover across W1/W2/W3. Keep queue gating on legacy first, then
# flip GAIALOG_QUEUE_GATE_SOURCE=overlay once parity and submit/admit SLOs are green.
BSV_SPEND_SOURCE_MODE=overlay
BSV_SPEND_SOURCE_SHADOW_READS=true
BSV_SPEND_SOURCE_LEGACY_FALLBACK_ENABLED=true
BSV_OVERLAY_CONFIRMED_ONLY=true
BSV_OVERLAY_TOPIC_PREFIX=TREASURY
BSV_OVERLAY_TOPIC_VERSION=v1
BSV_OVERLAY_AUTH_MODE=brc104
BSV_OVERLAY_FORCE_LEGACY_WALLETS=
BSV_OVERLAY_WALLET_FAILURE_THRESHOLD=3
BSV_OVERLAY_WALLET_FALLBACK_COOLDOWN_MS=300000
GAIALOG_QUEUE_GATE_SOURCE=legacy

# Overlay HTTP client
# These URLs point at the private loopback overlay service on the VPS.
# Mutual-auth headers are negotiated dynamically via BRC-104/Authrite; only
# x-bsv-* or Authorization headers are valid in the JSON header overrides below.
BSV_OVERLAY_PROVIDER_ID=donations-lookup
BSV_OVERLAY_LOOKUP_URL=http://127.0.0.1:3100/lookup
BSV_OVERLAY_SUBMIT_URL=http://127.0.0.1:3100/submit
BSV_OVERLAY_HEADERS_JSON={"x-bsv-originator":"gaialog-worker"}
BSV_OVERLAY_LOOKUP_HEADERS_JSON={"x-bsv-overlay-route":"lookup"}
BSV_OVERLAY_SUBMIT_HEADERS_JSON={"x-bsv-overlay-route":"submit"}
# Use distinct client/server identities in production. Reusing one WIF for both
# sides is acceptable only for short-lived smoke testing.
BSV_OVERLAY_CLIENT_IDENTITY_WIF=replace_me
BSV_OVERLAY_TIMEOUT_MS=15000
BSV_OVERLAY_MAX_RETRIES=3
BSV_OVERLAY_COUNT_FALLBACK_LIMIT=0
# Keep false globally for now; split outputs should still require all-host
# acknowledgement in the split/admission path as that lands.
BSV_OVERLAY_REQUIRE_ALL_HOST_ACKS=false

# Overlay server (PM2 loopback-only process on the VPS)
GAIALOG_OVERLAY_BIND_HOST=127.0.0.1
GAIALOG_OVERLAY_PORT=3100
GAIALOG_OVERLAY_HOST_ID=vps-1
GAIALOG_OVERLAY_SERVER_IDENTITY_WIF=replace_me
GAIALOG_OVERLAY_ALLOWED_IPS=127.0.0.1,::1,::ffff:127.0.0.1
# GAIALOG_OVERLAY_ALLOWED_IDENTITY_KEYS=
GAIALOG_OVERLAY_RATE_LIMIT_WINDOW_MS=60000
GAIALOG_OVERLAY_RATE_LIMIT_MAX=20000
GAIALOG_OVERLAY_JSON_LIMIT_BYTES=10485760
GAIALOG_OVERLAY_AUDIT_HMAC_SECRET=replace_me_with_a_long_random_string

# Explorer read-path egress tuning
EXPLORER_LOCATION_SAMPLE_LIMIT=400
EXPLORER_LOCATION_CACHE_TTL_MS=60000
EXPLORER_LOCATION_CACHE_MAX_ENTRIES=256
EXPLORER_SEARCH_CACHE_TTL_MS=15000
EXPLORER_SEARCH_CACHE_MAX_ENTRIES=128
EXPLORER_STATS_CACHE_TTL_MS=30000

# Explorer overlay migration — start with dual writes to populate the overlay
# table alongside the existing Supabase store.  Keep reads on legacy until
# parity is verified, then switch to shadow, then overlay.
EXPLORER_WRITE_MODE=dual
EXPLORER_READ_SOURCE=legacy

# Shared Postgres / Supabase (use Shared Pooler for IPv4 compatibility)
# From Supabase: Settings → Database → Connection string → Shared Pooler
PGHOST=aws-1-eu-west-1.pooler.supabase.com
PGPORT=5432
PGUSER=postgres.your_project_ref
PGPASSWORD=replace_me
PGDATABASE=postgres
PGPOOL_MAX=3
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_me
SUPABASE_SERVICE_ROLE_KEY=replace_me

# BSV signing / broadcasting
BSV_NETWORK=mainnet
BSV_WALLET_1_PRIVATE_KEY=replace_me
BSV_WALLET_2_PRIVATE_KEY=replace_me
BSV_WALLET_3_PRIVATE_KEY=replace_me
BSV_API_ENDPOINT=https://arc.taal.com
BSV_GORILLAPOOL_ARC_ENDPOINT=https://arc.gorillapool.io
BSV_ARC_API_KEY=replace_me
# BSV_GORILLAPOOL_API_KEY=

# Throughput / queue defaults
BSV_BYPASS_QUEUE=false
BSV_PREFER_CONFIRMED_UTXOS=true
# Legacy compatibility until PR6 replaces fixed auto-sizing with admission-driven
# deficit-fill targets and live fee telemetry.
BSV_EXPECTED_TX_PER_DAY=2000000
BSV_UTXO_SPLIT_OUTPUT_SATS=2000
BSV_UTXO_LOCK_TTL_MS=600000
# Reserved for the PR6 admission-driven splitter. Safe to set now; current code
# ignores these until the new splitter policy lands.
GAIALOG_UTXO_TARGET_BUFFER_MINUTES=5
GAIALOG_UTXO_HYSTERESIS_PCT=0.15
GAIALOG_SPLIT_PER_TX_CAP=256
GAIALOG_SPLIT_P95_HEADROOM=1.30

# Admin / operations
ADMIN_PASSWORD=replace_me
ADMIN_SECRET=replace_me_with_a_long_random_string

# Provider keys
WAQI_API_KEY=replace_me
WEATHERAPI_KEY=replace_me
OWM_API_KEY=replace_me
USGS_API_KEY=replace_me
