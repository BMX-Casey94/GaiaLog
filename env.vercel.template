# GaiaLog Vercel template
# Read-only frontend and read APIs. No signing keys, no ARC credentials,
# no queue mutation, and no background workers in this runtime.

NODE_ENV=production
GAIALOG_WORKER_PROCESS=0
GAIALOG_SINGLE_WRITER_MODE=run-workers
GAIALOG_MUTATOR_ROLE=secondary
GAIALOG_NO_DB=false
BSV_ENABLE_UTXO_DB_LOCKS=true
BSV_UTXO_MAINTAINER_DISABLED=true

# Read-side defaults while the spend path remains in phased rollout.
BSV_SPEND_SOURCE_MODE=legacy
BSV_SPEND_SOURCE_SHADOW_READS=true
BSV_SPEND_SOURCE_LEGACY_FALLBACK_ENABLED=true
BSV_OVERLAY_CONFIRMED_ONLY=true
BSV_OVERLAY_TOPIC_PREFIX=TREASURY
BSV_OVERLAY_TOPIC_VERSION=v1

# Database / Supabase
# Use the connection pooler on serverless hosts.
PGHOST=your-project.supabase.co
PGPORT=6543
PGUSER=postgres.your_project_ref
PGPASSWORD=replace_me
PGDATABASE=postgres
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_me
SUPABASE_SERVICE_ROLE_KEY=replace_me

# Public read-side configuration
BSV_NETWORK=mainnet
GAIALOG_DISABLE_WOC_READS=false
NEXT_PUBLIC_WOC_LIVE_URL=

# Optional read-only overlay lookup once explorer/history moves to overlay.
# Do not put signing credentials or privileged submit tokens in Vercel.
# BSV_OVERLAY_PROVIDER_ID=donations-lookup
# BSV_OVERLAY_LOOKUP_URL=https://185.249.72.134/lookup
# BSV_OVERLAY_HEADERS_JSON={}

# Admin UI
ADMIN_PASSWORD=replace_me
ADMIN_SECRET=replace_me_with_a_long_random_string
